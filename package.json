{
  "name": "dpdpreadycloudflare",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "vercel-build": "npm run build",
    "db:migrate": "node server/database/migrate.js",
    "lint": "eslint \"src/**/*.{js,jsx}\" \"server/**/*.{js,jsx}\"",
    "test": "node --test"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "react-toastify": "^10.0.5",
    "stripe": "^14.16.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "eslint": "^9.9.0",
    "vite": "^5.0.0"
  }
}
